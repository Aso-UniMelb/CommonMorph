@{
  ViewData["Title"] = "Linguist";
  Layout = "~/Views/Shared/_App.cshtml";
}

<div class="accordion">

  <div class="accordion-item" id="paradigm-accordion">
    <div class="accordion-header">Paradigm Structures</div>
    <div class="accordion-content">
      <label>
        <span class="addButton" id="btnAddInflectionClass"><span class="material-icons">add</span>Add</span>
      </label>
      <label>
        <span class="addButton" id="btnImportStructure"> <span class="material-icons">download</span> Import</span>
      </label>
      <label>
        <span class="addButton" id="btnExportStructure"> <span class="material-icons">upload</span> Export</span>
      </label>
      <ul id="lstInflectionClasses" class="list"></ul>
      <div id="frmInflectionClass" class="form">
        <form onsubmit="InflectionClassSubmit(); return false;">
          <input type="hidden" id="InflectionClassId" />
          <div class="field">
            <label for="txtInflectionClassTitle">Inflection Class Title</label>
            <input type="text" id="txtInflectionClassTitle" name="title" required />
          </div>
          <div class="field small">
            <label for="txtInflectionClassDescription">Description</label>
            <textarea id="txtInflectionClassDescription" name="description"></textarea>
          </div>
          <div class="field-end">
            <button type="button" id="btnInflectionClassCancel">Cancel</button>
            <button type="submit" id="btnInflectionClassSubmit"></button>
          </div>
        </form>
      </div>
      <div id="frmImportStructures" class="form">
        <form onsubmit="StructureImportSubmit(); return false;">
          <div class="field">
            <label>Import Script</label>
            <textarea id="txtStructureImport" rows="15"></textarea>
          </div>
          <div class="field-end">
            <button type="button" id="btnStructureImportCancel">Cancel</button>
            <button type="submit">Submit</button>
          </div>
        </form>
      </div>
      <div id="frmStructures" class="form">
        <form onsubmit="StructuresSubmit(); return false;">
          <input type="hidden" id="StructureId" />
          <input type="hidden" id="StructurePClassId" />
          <div class="field">
            <label for="txtStructureTitle">Structure Title/Alias</label>
            <input type="text" id="txtStructureTitle" name="Title" required />
          </div>
          <div class="field">
            <label for="txtStructureUniMorphTags">Morphosyntactic Feature</label>
            <div id="addedUMtags" class="addedUMtags"></div>
            <div id="StructureUMtagSelector" class="tagSelection"></div>
            <div class="unimorph">UniMorph:
              <input type="text" id="txtStructureUniMorphTags" name="UniMorphTags" requireddisabled />
            </div>
          </div>
          <div class="field">
            <label for="txtStructureFormula">Formula <small>(optional)</small></label>
            <input type="text" id="txtStructureFormula" name="formula" placeholder="S1+A" />
            <small>You can use: S1 (stem1), S2 (stem2), A (reusable layer), L (lemma)</small>
          </div>
          <div class="field">
            <label>Reusable Layer <small>(if Formula contains A)</small></label>
            <select id="cmbStructureReusableLayer" style="width: 300px;"></select>
          </div>
          <div class="field small">
            <label>Order</label>
            <input type="number" id="txtStructureOrder" name="order" min="0" max="50" step="1" required />
          </div>
          <div class="field-end">
            <button type="button" id="btnStructuresCancel">Cancel</button>
            <button type="submit" id="btnStructuresSubmit"></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item" id="affix-accordion">
    <div class="accordion-header">Reusable Layers</div>
    <div class="accordion-content">
      <label>
        <span class="addButton" id="btnAddReusableLayer"><span class="material-icons">add</span> Add</span>
      </label>
      <label>
        <span class="addButton" id="btnImportAffixes"> <span class="material-icons">download</span> Import</span>
      </label>
      <label>
        <span class="addButton" id="btnExportAffixes"> <span class="material-icons">upload</span> Export</span>
      </label>
      <ul id="lstReusableLayers" class="list"></ul>
      <div id="frmImportAffix" class="form">
        <form onsubmit="AffixImportSubmit(); return false;">
          <div class="field">
            <label>Import Affix Script</label>
            <textarea id="txtAffixImport" rows="15"></textarea>
          </div>
          <div class="field-end">
            <button type="button" id="btnAffixImportCancel">Cancel</button>
            <button type="submit" id="btnAffixImportSubmit">Submit</button>
          </div>
        </form>
      </div>
      <div id="frmReusableLayer" class="form">
        <form onsubmit="ReusableLayerSubmit(); return false;">
          <input type="hidden" id="ReusableLayerId" />
          <div class="field">
            <label>Reusable Layer Title</label>
            <input type="text" id="txtReusableLayerTitle" name="title" required />
          </div>
          <div class="field-end">
            <button type="button" id="btnReusableLayerCancel">Cancel</button>
            <button type="submit" id="btnReusableLayerSubmit"></button>
          </div>
        </form>
      </div>
      <div id="frmAffix" class="form">
        <form onsubmit="AffixSubmit(); return false;">
          <input type="hidden" id="AffixId" />
          <input type="hidden" id="AffixGroupId" />
          <div class="field">
            <label for="txtAffixTitle">Reusable Morpheme Title/Alias</label>
            <input type="text" id="txtAffixTitle" name="Title" placeholder="1st person singular" required />
          </div>
          <div class="field">
            <label for="txtAffixRealization">Morpheme</label>
            <input type="text" id="txtAffixRealization" name="Realization" required />
          </div>
          <div class="field">
            <label for="txtAffixUniMorphTags">Morphosyntactic Feature</label>
            <div id="addedUMtagsA" class="addedUMtags"></div>
            <div id="AffixUMtagSelector" class="tagSelection"></div>
            <div class="unimorph">UniMorph:
              <input type="text" id="txtAffixUniMorphTags" name="UniMorphTags" required disabled />
            </div>
          </div>
          <div class="field small">
            <label>Order</label>
            <input type="number" id="txtAffixOrder" name="order" min="0" max="50" step="1" required />
          </div>
          <div class="field-end">
            <button type="button" id="btnAffixCancel">Cancel</button>
            <button type="submit" id="btnAffixSubmit"></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item" id="lemma-accordion">
    <div class="accordion-header">Lexicon</div>
    <div class="accordion-content">
      <label>
        <span class="addButton" id="btnAddLemma"><span class="material-icons">add</span>Add</span>
      </label>
      <label>
        <span class="addButton" id="btnImportLemmas"> <span class="material-icons">download</span> Import</span>
      </label>
      <label>
        <span class="addButton" id="btnExportLemmas"> <span class="material-icons">upload</span> Export</span>
      </label>
      <ul id="lstLemmas" class="list"></ul>
      <div id="frmImportLemmas" class="form">
        <form onsubmit="LemmaImportSubmit(); return false;">
          <div class="field">
            <label>Import Script</label>
            <textarea id="txtLemmaImport" rows="15"></textarea>
          </div>
          <div class="field-end">
            <button type="button" id="btnLemmaImportCancel">Cancel</button>
            <button type="submit">Submit</button>
          </div>
        </form>
      </div>
      <div id="frmLemmas" class="form">
        <form onsubmit="LemmasSubmit(); return false;">
          <input type="hidden" id="LemmaId" />
          <div class="field">
            <label>Inflection Class</label>
            <select id="cmbLemmaInflectionClass" style="width: 300px;" required></select>
          </div>
          <div class="field">
            <label>Gloss (Meaning)</label>
            <input type="text" id="txtLemmaEnglish" name="EngMeaning" required />
          </div>
          <div class="field">
            <label>Lemma (Dictionary Entry)</label>
            <input type="text" id="txtLemmaEntry" name="entry" required />
          </div>
          <div class="field">
            <label>Stem1 <small>(optional)</small></label>
            <input type="text" id="txtLemmaStem1" name="Stem1" />
          </div>
          <div class="field">
            <label>Stem2 <small>(optional)</small></label>
            <input type="text" id="txtLemmaStem2" name="Stem2" />
          </div>
          <details>
            <summary>More Stems</summary>
            <div class="field">
              <label>Stem3 <small>(optional)</small></label>
              <input type="text" id="txtLemmaStem3" name="Stem3" />
            </div>
            <div class="field">
              <label>Stem4 <small>(optional)</small></label>
              <input type="text" id="txtLemmaStem4" name="Stem4" />
            </div>
          </details>
          <div class="field small">
            <label>Description <small>(optional)</small></label>
            <input type="text" id="txtLemmaDescription" name="Description" />
          </div>
          <div class="field small">
            <label>Priority</label>
            <select id="cmbLemmaPriority" style="width: 100px;" required>
              <option value="0" selected>Low</option>
              <option value="1">Medium</option>
              <option value="2">High</option>
            </select>
          </div>
          <div class="field-end">
            <button type="button" id="btnLemmasCancel">Cancel</button>
            <button type="submit" id="btnLemmasSubmit"></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item" id="morphophonemics-accordion">
    <div class="accordion-header">Morphophonological Rules</div>
    <div class="accordion-content">
      <label>
        <span class="addButton" id="btnAddMorphophonemicRule"><span class="material-icons">add</span>Add</span>
      </label>
      <ul id="lstMorphophonemicRules" class="list"></ul>
      <div id="frmMorphophonemicRule" class="form">
        <form onsubmit="MorphophonemicRuleSubmit(); return false;">
          <input type="hidden" id="MorphophonemicRuleId" />
          <div class="field">
            <label for="txtMorphophonemicRuleTitle">Layer Title</label>
            <input type="text" id="txtMorphophonemicRuleTitle" name="title" required />
          </div>
          <div class="field2cols">
            <div class="field">
              <label for="txtMorphophonemicRuleReplaceFrom">Replaces From</label>
              <textarea id="txtMorphophonemicRuleReplaceFrom" name="replacefrom" required></textarea>
            </div>
            <div class="field">
              <label for="txtMorphophonemicRuleReplaceTo">Replaces To</label>
              <textarea id="txtMorphophonemicRuleReplaceTo" name="replaceto" required></textarea>
            </div>
          </div>
          <div class="field-end">
            <button type="button" id="btnMorphophonemicRuleCancel">Cancel</button>
            <button type="submit" id="btnMorphophonemicRuleSubmit"></button>
          </div>
        </form>
      </div>
    </div>
  </div>

</div>

<div id="popup" class="popup">
  <div class="popup-content">
    <div id="closePopup" class="close">&times;</div>
    <div id="popupContent"></div>
  </div>
</div>
<script src="/js/myLang.js" asp-append-version="true"></script>
<script src="/js/UM_tags.js" asp-append-version="true"></script>
<script src="/js/linguist.js" asp-append-version="true"></script>
<script src="/js/lexicon.js" asp-append-version="true"></script>
<script src="/js/structures.js" asp-append-version="true"></script>
<script src="/js/affixes.js" asp-append-version="true"></script>
<script src="/js/morphophonology.js" asp-append-version="true"></script>
<script>
  $(document).ready(function () {
    $('#frmLang').hide();
    $('#frmInflectionClass').hide();
    $('#frmReusableLayer').hide();
    $('#frmImportAffix').hide();
    $('#frmImportStructures').hide();
    $('#frmImportLemmas').hide();
    $('#frmLemmas').hide();
    $('#frmStructures').hide();
    $('#frmAffix').hide();
    $('#popup').hide();
  });
</script>